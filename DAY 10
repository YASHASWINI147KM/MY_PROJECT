#include <stdio.h>

int main() {
    float P, R, T, SI, total;

    printf("Enter Principal amount: ");
    scanf("%f", &P);
    printf("Enter Rate of interest: ");
    scanf("%f", &R);
    printf("Enter Time (in years): ");
    scanf("%f", &T);

    SI = (P * R * T) / 100;
    total = P + SI;

    printf("Simple Interest: %.2f\n", SI);
    printf("Total Amount: %.2f\n", total);

    return 0;
}
