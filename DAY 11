//for range 
#include <stdio.h>
int main() {

  int n, i, range;
  printf("Enter an integer: ");
  scanf("%d", &n);
  do {
    printf("Enter the range (positive integer): ");
    scanf("%d", &range);
  } while (range <= 0);

  for (i = 1; i <= range; ++i) {
    printf("%d * %d = %d \n", n, i, n * i);
  }

  return 0;
}


//from 1 to 5
#include <stdio.h>

int main() {
    int i, j;

  
    for (i = 1; i <= 5; i++) {
        printf("Multiplication Table of %d:\n", i);

  
        for (j = 1; j <= 10; j++) {
            printf("%d x %d = %d\n", i, j, i * j);
        }
        
      
        printf("\n");
    }

    return 0;
}
