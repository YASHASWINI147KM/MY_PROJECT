//PRIME NUMBER FROM 1 TO 100

#include <stdio.h>

int main() {
    int i, j, isPrime;

    for(i = 2; i <= 100; i++) {
        isPrime = 1;
        for(j = 2; j < i; j++) {
            if(i % j == 0) {
                isPrime = 0;
                break;
            }
        }
        if(isPrime == 1) {
            printf("%d ", i);
        }
    }

    return 0;
}


//TO CHECK THE NUMBER IS PRIME
#include <stdio.h>

int main() {
    int num, i, j, isPrime;

    // Input from user
    printf("Enter a positive integer: ");
    if (scanf("%d", &num) != 1 || num <= 0) {
        printf("Invalid input. Please enter a positive integer.\n");
        return 1;
    }

    // Numbers less than 2 are not prime
    if (num < 2) {
        printf("%d is NOT a prime number.\n", num);
        return 0;
    }

    // Outer loop runs only once for the given number
    for (i = num; i <= num; i++) {
        isPrime = 1; // Assume prime initially

        // Inner loop checks divisibility
        for (j = 2; j <= i / 2; j++) {
            if (i % j == 0) {
                isPrime = 0; // Found a divisor
                break;       // No need to check further
            }
        }

        // Output result
        if (isPrime)
            printf("%d is a PRIME number.\n", i);
        else
            printf("%d is NOT a prime number.\n", i);
    }

    return 0;
}
