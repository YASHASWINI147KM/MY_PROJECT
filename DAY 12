//For n natural numbers
#include <stdio.h>

int main() {
    int n, sum = 0;
    printf("Enter a positive integer: ");
    scanf("%d", &n);

    for(int i = 1; i <= n; i++) {
        sum += i; // Adds i to sum in each step
    }

    printf("Sum of first %d natural numbers is: %d", n, sum);
    return 0;
}


//For even numbers 
#include <stdio.h>

int main() {
    int n, sum = 0;
    printf("Enter the limit N: ");
    scanf("%d", &n);

    for(int i = 2; i <= n; i += 2) {
        sum += i;
    }

    printf("Sum of even numbers up to %d is: %d", n, sum);
    return 0;
}
